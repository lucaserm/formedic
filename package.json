{
  "name": "formedic",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "build": "bun build src/server.ts --target bun --outdir ./dist",
    "start": "NODE_ENV=production bun dist/server.js",
    "test": "bun test",
    "db:migrate": "drizzle-kit generate && drizzle-kit migrate",
    "db:seed": "bun run scripts/seed.ts"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.9",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@faker-js/faker": "^10.3.0",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.25",
    "elysia-rate-limit": "^4.5.0",
    "pg": "^8.18.0",
    "prom-client": "^15.1.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  }
